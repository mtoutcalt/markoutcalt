---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import { ClientRouter } from 'astro:transitions';
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Progressbar from "../components/progressBar.astro"
import SquigglyHR from '../components/SquigglyHR.astro';

type Props = CollectionEntry<"blog">["data"] & { ogImage?: string };

const { title, description, pubDate, updatedDate, heroImage, tags, ogImage } = Astro.props;

const blogJsonLd = pubDate && {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": "https://www.markoutcalt.com/blog/" + title,
  },
  headline: title,
  description: description,
  image: heroImage,
  author: {
    "@type": "Person",
    name: "Mark O.",
    url: "https://www.markoutcalt.com",
  },
  publisher: {
    "@type": "Person",
    name: "Mark O.",
    logo: {
      "@type": "ImageObject",
      url: "https://www.markoutcalt.com/favicon.svg",
    },
  },
  datePublished: pubDate.toISOString(),
  dateModified: updatedDate?.toISOString(),
};

// Construct JSON-LD data for the website
const searchJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Mark's Blog",
  url: "https://www.markoutcalt.com",
  logo: "https://www.markoutcalt.com/favicon.svg",
  sameAs: [
    "https://mastodon.social/@markoutcalt",
    "https://github.com/mtoutcalt",
	"www.linkedin.com/in/mark-outcalt-b3391529",
  ]
};
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={ogImage} />
		<!-- <ClientRouter /> -->
		{
			blogJsonLd && (
			  <script
				type="application/ld+json"
				set:html={JSON.stringify(blogJsonLd)}
			  />
			)
		  }
		      <script
			  	type="application/ld+json"
			  	set:html={JSON.stringify(searchJsonLd)}
			  />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 800px;
				max-width: calc(100% - 1em);
				margin: auto;
				padding: 0em;
				color: var(--text-color);
			}
			.title {
				margin: 0 auto 1.75em;
				padding: 1.5em 0 0.75em;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0.65em 0;
				padding: 0;
				color: var(--color-theme-1);
				font-size: 5.5rem;
				line-height: 1;
				letter-spacing: -2px;
				word-spacing: -4px;
			}
			.last-updated-on {
				font-style: italic;
				font-size: 12px;
				opacity: 0.7;
				margin-left: 0.4em;
			}
			/* Decorative row: line — dot — [content] — dot — line */
			.header-deco-row {
				display: flex;
				align-items: center;
				width: 100%;
			}
			.h-line {
				flex: 1;
				height: 1px;
				background: var(--hr-color);
			}
			.h-dot {
				width: 7px;
				height: 7px;
				border-radius: 50%;
				background: var(--hr-color);
				flex-shrink: 0;
				margin: 0 8px;
			}
			.header-tag-pill {
				border: 1px solid var(--hr-color);
				border-radius: 20px;
				padding: 4px 18px;
				font-size: 0.8rem;
				letter-spacing: 0.04em;
				white-space: nowrap;
				color: var(--text-color);
				text-transform: capitalize;
			}
			.author-meta {
				display: flex;
				align-items: center;
				gap: 0.6rem;
				padding: 0 1rem;
			}
			.author-avatar {
				width: 34px;
				height: 34px;
				border-radius: 50%;
				background: var(--color-theme-1);
				color: var(--bg-color);
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 0.7rem;
				font-weight: 700;
				flex-shrink: 0;
				letter-spacing: 0.02em;
			}
			.author-info {
				display: flex;
				flex-direction: column;
				align-items: flex-start;
				gap: 0.1rem;
				line-height: 1.3;
			}
			.author-name {
				font-size: 0.85rem;
				font-weight: 600;
				color: var(--text-color);
			}
			.author-date {
				font-size: 0.78rem;
				color: var(--text-color);
				opacity: 0.65;
			}
			@media (max-width: 720px) {
				.last-updated-on {
					font-size: 10px;
				}
				main {
					width: calc(100% - 1em);
					max-width: 100%;
					margin: 0;
				}
				.title h1 {
					margin: 0.5em 0;
					color: var(--color-theme-1);
					font-size: 2em;
					letter-spacing: 0px;
				}
				.author-meta {
					padding: 0 0.5rem;
				}
			}
		</style>
	</head>

	<body>
		<Progressbar />
		<Header />
		<main role="main">
			<article role="article">
				<div class="hero-image">
					{
						heroImage && (
							<img
								width={1020}
								height={510}
								src={heroImage}
								alt={`Hero image for blog post: ${title}`}
							/>
						)
					}
				</div>
				<div class="prose">
					<div class="title">
						<!-- Top: decorative line — dot — tag pill — dot — line -->
						<div class="header-deco-row">
							<span class="h-line"></span>
							<span class="h-dot"></span>
							<span class="header-tag-pill">
								{tags && tags.length > 0 ? tags[0] : "Article"}
							</span>
							<span class="h-dot"></span>
							<span class="h-line"></span>
						</div>

						<h1>{title}</h1>

						<!-- Bottom: decorative line — dot — author meta — dot — line -->
						<div class="header-deco-row">
							<span class="h-line"></span>
							<span class="h-dot"></span>
							<div class="author-meta">
								<div class="author-avatar">MO</div>
								<div class="author-info">
									<span class="author-name">Mark O.</span>
									<span class="author-date"><FormattedDate date={pubDate} /></span>
								</div>
								{updatedDate &&
									<span class="last-updated-on">
										(Updated: <FormattedDate date={updatedDate} />)
									</span>}
							</div>
							<span class="h-dot"></span>
							<span class="h-line"></span>
						</div>
					</div>
					<slot />
					        <SquigglyHR width="100%" variant="bouncy" color1="#ff6b6b" color2="#4ecdc4" />

					<nav aria-label="Blog navigation">
						<a href="/blog" aria-label="Return to blog post list">↩ More posts</a>
					</nav>
				</div>
			</article>
		</main>

		<Footer />
	</body>
</html>
